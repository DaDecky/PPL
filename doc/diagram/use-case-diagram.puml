@startuml Use Case Diagram
left to right direction

' =====================
' ACTORS
' =====================
actor "TAMU"  as TAMU
actor "USER"  as USER
actor "ADMIN" as ADMIN

' =====================
' SYSTEM BOUNDARY
' =====================
rectangle "Sistem Infak & Filantropi — Rumah Amal Salman" {

        ' --- KOLOM KIRI (Tamu & User Usecases) ---
        together {
                usecase "UC-01\nRegistrasi Akun"              as UC01
                usecase "UC-04\nDonasi Anonim"                as UC04
                usecase "UC-17\nManajemen Profil"             as UC17
                usecase "UC-03\nDonasi Terautentikasi"        as UC03
                usecase "UC-05\nPengajuan Pinjaman"           as UC05
                usecase "UC-08\nPenyetujuan SPK"              as UC08
                usecase "UC-10\nPembayaran Cicilan"           as UC10
                usecase "UC-11\nLihat Riwayat Cicilan"        as UC11
                usecase "UC-12\nReminder Tagihan"             as UC12
                usecase "UC-13\nLihat Transparansi Dana"      as UC13
                usecase "UC-15\nLihat Laporan Cash Flow Pribadi" as UC15
        }

        ' --- TENGAH (Shared Usecase) ---
        usecase "UC-02\nAutentikasi Login/Logout"     as UC02

        ' --- KOLOM KANAN (Admin Usecases) ---
        together {
                usecase "UC-06\nVerifikasi Pengajuan Pinjaman" as UC06
                usecase "UC-07\nPenerbitan SPK"               as UC07
                usecase "UC-09\nPantau Status Pencairan Dana" as UC09
                usecase "UC-14\nLihat Dashboard Admin"        as UC14
                usecase "UC-16\nLihat Laporan Cash Flow Keseluruhan" as UC16
        }

        ' --- INVISIBLE LINKS UNTUK MEMAKSA LAYOUT KOLOM ---
        ' Ini mendorong grup kanan agar posisinya sejajar di sebelah kanan grup kiri
        UC01 -[hidden]-> UC06
        UC05 -[hidden]-> UC07
        UC10 -[hidden]-> UC09
        UC13 -[hidden]-> UC14
        UC15 -[hidden]-> UC16
}

